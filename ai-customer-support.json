    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "groqApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"temperature\": 0.3,\n  \"max_tokens\": 500,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert customer support AI for an e-commerce company.\\n\\nYour job:\\n- Analyze the customer message carefully\\n- Classify it accurately\\n- Respond warmly and professionally\\n- Detect urgency and emotion\\n- Use customer history to personalize your response\\n\\nRules:\\n- needs_human = true if: payment dispute, account hacked, legal threat, extremely angry, complex technical issue, custom API integration\\n- priority = high if: payment issue, no access to account, words like urgent/immediately/lawsuit, or customer has 3+ previous unresolved issues\\n- priority = low if: general question, curiosity, compliment\\n- Always reply in the SAME language the customer used\\n- Keep response under 3 sentences, warm and helpful\\n- Never make up order numbers or promises\\n- If customer is a repeat complainer on same issue, acknowledge it and escalate\\n\\nRespond ONLY with this exact JSON, no extra text:\\n{\\n  \\\"category\\\": \\\"billing|shipping|technical|general\\\",\\n  \\\"priority\\\": \\\"high|medium|low\\\",\\n  \\\"sentiment\\\": \\\"angry|frustrated|neutral|satisfied\\\",\\n  \\\"needs_human\\\": true,\\n  \\\"response\\\": \\\"your reply here\\\",\\n  \\\"internal_note\\\": \\\"one line for the support team\\\"\\n}\\n\\nCUSTOMER HISTORY:\\n{{ $('Code in JavaScript1').first().json.customer_history }}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Customer: {{ $('Code in JavaScript1').first().json.name }}, Email: {{ $('Code in JavaScript1').first().json.email }}, Message: {{ $('Code in JavaScript1').first().json.message }}\"\n    }\n  ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        624,
        16
      ],
      "id": "766b9d3e-a2c7-4c15-a23d-f836de3ffc06",
      "name": "HTTP Request",
      "retryOnFail": true,
      "waitBetweenTries": 2000,
      "credentials": {
        "groqApi": {
          "id": "HPqV8Vvjvg1NGKa5",
          "name": "Groq account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.choices[0].message.content;\nconst parsed = JSON.parse(raw);\n\nreturn [{\n  json: {\n    ...parsed,\n    customer_name: $('Webhook').first().json.body.name,\n    customer_email: $('Webhook').first().json.body.email,\n    original_message: $('Webhook').first().json.body.message,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        16
      ],
