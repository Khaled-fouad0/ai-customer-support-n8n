        "jsCode": "const rows = $input.all().map(item => item.json);\n\nconst categoryCounts = {};\nrows.forEach(row => {\n  const cat = row.Category || 'general';\n  categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;\n});\n\nconst topCategoryEntry = Object.entries(categoryCounts)\n  .sort((a, b) => b[1] - a[1])[0];\n\nconst last3 = rows.slice(-3).map(row => \n  `[${row.Timestamp?.slice(0,10)}] ${row.Category} (${row.Priority}): '${row.Message}'`\n).join(' | ');\n\nconst customerHistory = rows.length === 0 \n  ? 'New customer, no history.'\n  : `Customer has ${rows.length} previous tickets. Most common issue: ${topCategoryEntry[0]} (${topCategoryEntry[1]} times). Last 3 messages: ${last3}`;\n\nreturn [{\n  json: {\n    customer_history: customerHistory,\n    total_tickets: rows.length,\n    top_category: topCategoryEntry ? topCategoryEntry[0] : 'none',\n    name: $('Webhook').first().json.body.name,\n    email: $('Webhook').first().json.body.email,\n    message: $('Webhook').first().json.body.message\n  }\n}];"
